# ============================================================
#  Universal Campus Info Chatbot — Environment Configuration
# ============================================================

# -----------------------------------------------------------
# LLM Configuration (Google Gemini)
# -----------------------------------------------------------
# Get your free Gemini API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Gemini model to use (gemini-1.5-flash is free and fast)
GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------
# App Configuration
# -----------------------------------------------------------
# Display name shown in the chatbot UI
COLLEGE_NAME=Universal Campus Assistant

# App theme (dark or light)
APP_THEME=dark

# Max chat history messages to retain in context
MAX_HISTORY=10

# -----------------------------------------------------------
# Vector Store
# -----------------------------------------------------------
# Path to store FAISS index (relative to project root)
VECTOR_STORE_PATH=./vector_store

# Embedding model (free, runs locally)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# -----------------------------------------------------------
# Database
# -----------------------------------------------------------
DB_PATH=./campus.db

# -----------------------------------------------------------
# Web Scraping (optional — for live website scraping)
# -----------------------------------------------------------
# Add college website URLs to scrape (comma-separated)
# COLLEGE_URLS=https://example-college.ac.in,https://another-college.edu.in

# -----------------------------------------------------------
# Logging
# -----------------------------------------------------------
LOG_LEVEL=INFO
