    "credit_system": {
      "formula": "C = 0.5 × n, where n is the number of segments a course spans",
      "full_course": "A full-semester 3-contact-hour theory course = 3 credits (spans all 6 segments)",
      "segment_credit": "Each individual segment = 0.5 credits",
      "example": "A course running in Segments 5 and 6 (Segment 56) spans n=2 segments → C = 0.5 × 2 = 1.0 credit",
      "breadth_courses": "1 credit (short, 2-week intensive courses)",
      "depth_courses": "1.5 to 2.5 credits (specialized courses spanning multiple segments)"
    },
    "benefits": [
      "Promotes interdisciplinary exploration through short breadth courses",
      "Reduces student stress by breaking large courses into manageable segments",
      "Allows faster course completion and flexible scheduling",
      "Students can complete a second major by taking extra credits from 4th semester onward, provided no active academic backlogs"
    ]
  },

